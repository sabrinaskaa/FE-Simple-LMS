# Backend API Target URL (Vite Dev Server Proxy target)
# In development, Django API runs on http://localhost:8000 by default.
# If you are using Docker, use the mapped port for the backend app.
VITE_API_TARGET_URL=http://localhost:8000

# Backend API Base Path (defaults to /api/v1)
VITE_API_BASE_URL=/api/v1
